# One passphrase per person, so the site knows whose take it's saving.
# Both must be set and they must differ, or the gate refuses every attempt.
# SITE_PASSWORD is a deprecated alias for SITE_PASSWORD_JAMES; don't set it in new setups.
SITE_PASSWORD_JAMES=
SITE_PASSWORD_LIAM=

# Signs the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Changing this signs everyone out.
SESSION_SECRET=

# Neon Postgres, for per-author takes and comments. Optional: leave it unset and
# takes silently no-op while the rest of the site works.
DATABASE_URL=
